# ========== 应用 ==========
AGENTFORGE_ENV=dev
# 生产环境务必更换为随机长字符串（用于 JWT 签名）
SECRET_KEY=change-me-to-a-long-random-string
# 注册邀请码：公开部署建议设置；配置管理员用户名时必须同时设置邀请码
REGISTRATION_INVITE_CODE=
# 多用户运营：只有使用正确邀请码注册的该用户名会成为管理员
ADMIN_USERNAME=
# 每用户每日 token 额度（0=不限）；管理员不受限
DAILY_TOKEN_QUOTA=200000

# ========== 数据库 ==========
# 完整模式（Docker Compose 启动 PostgreSQL + pgvector）：
DATABASE_URL=postgresql+asyncpg://agentforge:agentforge@localhost:5432/agentforge
# 轻量模式（无需 Docker，向量检索自动降级为进程内计算）：
# DATABASE_URL=sqlite+aiosqlite:///./agentforge.db
# 也支持 PaaS 的 postgres:// / postgresql:// 连接串（应用会自动转成 asyncpg 驱动）

# 是否使用 pgvector（Postgres）。不带 pgvector 的托管库（Railway/Zeabur 默认）会自动降级为
# JSON 存向量 + 进程内检索，功能不受影响；也可显式设为 false 强制降级。
USE_PGVECTOR=true

# Redis（限流用；未启动时自动降级为进程内限流）
REDIS_URL=redis://localhost:6379/0

# ========== 对话模型（OpenAI 兼容协议，填 Key 即用）==========
# 可选值: deepseek | qwen | openai | glm | moonshot | custom | mock
# mock = 无需任何 Key 的确定性演示模式，全流程可跑通
LLM_PROVIDER=mock
LLM_API_KEY=
# 不填则使用各厂商默认模型: deepseek-chat / qwen-plus / gpt-4o-mini / glm-4-flash / moonshot-v1-8k
LLM_MODEL=
# provider=custom 时必填（任意 OpenAI 兼容端点，如 vLLM / Ollama / 中转站）
LLM_BASE_URL=

# 评审模型（LLM-as-judge / 报告评审，不填则复用上面的对话模型）
JUDGE_PROVIDER=
JUDGE_API_KEY=
JUDGE_MODEL=

# ========== Embedding 模型 ==========
# 可选值: qwen | openai | custom | mock （DeepSeek 暂无 embedding API）
EMBEDDING_PROVIDER=mock
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_BASE_URL=
EMBEDDING_DIM=1024

# ========== 检索增强（可选）==========
# Web 搜索：填了 Tavily 用 Tavily，否则尝试 DuckDuckGo；失败返回空结果，不伪造来源
TAVILY_API_KEY=
# 重排序 API（Jina / DashScope gte-rerank 等兼容格式，不填则跳过重排）
RERANK_API_KEY=
RERANK_MODEL=
RERANK_BASE_URL=

# ========== Agent 运行参数 ==========
AGENT_MAX_STEPS=8
AGENT_TOKEN_BUDGET=40000
RESEARCH_MAX_WORKERS=3
MAX_CONCURRENT_RUNS=8
MAX_CONCURRENT_RUNS_PER_USER=2
MAX_CONCURRENT_RUNS_PER_SESSION=1
# 内置 Python 子进程仅供本地演示，不具备生产容器级隔离；生产必须为 false
SANDBOX_ENABLED=true
SANDBOX_TIMEOUT=20
# Python 沙箱工具是否需要人工审批（human-in-the-loop）
SANDBOX_REQUIRES_APPROVAL=true
# 自定义 HTTP 工具存在出口访问风险；只在受信任的本地/内网环境显式启用
CUSTOM_HTTP_TOOLS_ENABLED=true

# ========== 限流 ==========
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_RESEARCH_PER_MINUTE=5

# ========== 安全护栏 ==========
GUARDRAILS_ENABLED=true
GUARDRAILS_BLOCK_INJECTION=true
GUARDRAILS_MASK_PII=true
GUARDRAILS_MODERATION=true

# ========== 语义缓存 ==========
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.93
SEMANTIC_CACHE_TTL_SECONDS=86400

# ========== RAG 进阶（改写/HyDE/压缩会增加 LLM 调用，按需开启）==========
RAG_QUERY_REWRITE=false
RAG_HYDE=false
RAG_COMPRESSION=false
RAG_PARENT_CHILD=true

# ========== MCP（接入外部 MCP 工具服务器）==========
# 指向 JSON 配置文件，例如 mcp.config.json：
#   {"mcpServers": {"demo": {"command": "python", "args": ["samples/mcp_server.py"]}}}
MCP_CONFIG_PATH=
